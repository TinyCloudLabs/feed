{
  "name": "@tinycloudlabs/feed",
  "version": "0.0.1",
  "private": true,
  "description": "Feed v1 client for the separate TinyCloud Feed Host.",
  "type": "module",
  "scripts": {
    "tc": "tc",
    "dev": "portless run --name feed vite",
    "dev:local": "VITE_FEED_HOST_URL=http://127.0.0.1:8787 vite --host 127.0.0.1 --port 5173",
    "dev:vite": "vite",
    "host": "bun run host/server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "test": "bun test --preload ./host/no-spend-setup.ts web/src host",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test e2e/specs/openkey-wallet-feed-flow.pw.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.host.json"
  },
  "dependencies": {
    "@openkey/sdk": "^0.8.4",
    "@tinycloud/node-sdk": "2.6.4-beta.1",
    "@tinycloud/web-sdk": "2.6.4-beta.1",
    "ethers": "^5.7.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tinycloud/cli": "0.6.0-beta.11",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "portless": "^0.14.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "packageManager": "bun@1.3.12"
}
