{
  "permissions": [
    {
      "service": "tinycloud.sql",
      "space": "applications",
      "path": "xyz.tinycloud.listen/conversations",
      "actions": ["read"],
      "skipPrefix": true,
      "description": "Read approved Listen conversation records for local Feed testing."
    },
    {
      "service": "tinycloud.kv",
      "space": "applications",
      "path": "xyz.tinycloud.listen/transcript/",
      "actions": ["get", "list"],
      "skipPrefix": true,
      "description": "Read and enumerate approved Listen transcript documents for local Feed testing."
    }
  ]
}
