# Feed front-end environment (Vite — only VITE_-prefixed vars reach the client).
# Copy to `.env` for local dev, or set in the Cloudflare Pages project settings.

# The distillery agent backend (info / delegation / run endpoints). When UNSET,
# the agent UI shows a clear "agent backend not configured" state and the feed is
# still readable. For local dev this is typically a localhost port or a tunnel.
VITE_AGENT_HOST=http://localhost:8787

# The per-install bearer token the agent backend requires on POST /agent/delegation
# and POST /agent/run. Read it from the backend's persisted file
# (`cat <AGENT_STATE_DIR>/api-token`) or set AGENT_API_TOKEN on the backend. When
# UNSET here, those POSTs carry no auth header and the backend answers 401.
# VITE_AGENT_TOKEN=

# Optional: the agent's stable did:pkh. When set, it's declared as a manifest
# delegation target so the SDK lists the delegate explicitly. NOT required — the
# delegateTo derivation only needs the broadened recap, not the DID.
# VITE_AGENT_DID=

# OpenKey passkey host (sign-in). Default: https://openkey.so
VITE_OPENKEY_HOST=https://openkey.so

# TinyCloud node host (storage). Default: https://node.tinycloud.xyz
VITE_TINYCLOUD_HOST=https://node.tinycloud.xyz
