# Feed front-end environment (Vite — only VITE_-prefixed vars reach the client).
# Copy to `.env` for local dev, or set in the Cloudflare Pages project settings.

# Feed Host API. The app reads projections/artifacts and posts feedback/control
# intents through this server; it does not read TinyCloud SQL directly.
VITE_FEED_HOST_URL=https://api.feed.tinycloud.xyz
# Local development Feed Host:
# VITE_FEED_HOST_URL=http://127.0.0.1:8787

# Optional bearer for Feed Host installs that require one.
# VITE_FEED_HOST_TOKEN=

# OpenKey passkey host (sign-in). Default: https://openkey.so
VITE_OPENKEY_HOST=https://openkey.so

# TinyCloud node host (storage). Default: https://node.tinycloud.xyz
VITE_TINYCLOUD_HOST=https://node.tinycloud.xyz

# Local Feed Host server settings.
FEED_HOST_HOSTNAME=127.0.0.1
FEED_HOST_PORT=8787
FEED_HOST_SEED=1
# Set in hosted environments so the Feed Host delegate DID is stable across restarts.
# If unset locally, the host uses a generated session DID for development.
# FEED_HOST_PRIVATE_KEY=
